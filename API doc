<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NEXUS v5 — Developer Documentation</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:       #07080a;
  --bg2:      #0d0f12;
  --bg3:      #12151a;
  --bg4:      #181c22;
  --border:   #1e2530;
  --border2:  #2a3340;
  --amber:    #f5a623;
  --amber2:   #ffc045;
  --green:    #00d68f;
  --red:      #ff4560;
  --blue:     #00b4d8;
  --purple:   #9d4edd;
  --text:     #c8d6e5;
  --text2:    #8899aa;
  --text3:    #4a5568;
  --text4:    #2a3340;
  --mono:     'Share Tech Mono', monospace;
  --display:  'Orbitron', monospace;
  --body:     'Inter', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--body);
  font-size: 14px;
  line-height: 1.7;
  display: flex;
  min-height: 100vh;
}

/* ── SIDEBAR ── */
.sidebar {
  width: 260px;
  flex-shrink: 0;
  background: var(--bg2);
  border-right: 1px solid var(--border2);
  height: 100vh;
  position: sticky;
  top: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: var(--bg2); }
.sidebar::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

.sb-logo {
  padding: 20px 20px 16px;
  border-bottom: 1px solid var(--border2);
  flex-shrink: 0;
}
.sb-logo-title {
  font-family: var(--display);
  font-size: 16px;
  font-weight: 900;
  color: var(--amber);
  letter-spacing: 4px;
}
.sb-logo-sub {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 2px;
  margin-top: 4px;
}
.sb-version {
  display: inline-block;
  font-family: var(--mono);
  font-size: 9px;
  background: var(--bg4);
  border: 1px solid var(--border2);
  color: var(--amber);
  padding: 2px 8px;
  border-radius: 2px;
  margin-top: 8px;
}

.sb-section {
  padding: 14px 20px 4px;
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 2px;
  text-transform: uppercase;
}

.sb-link {
  display: block;
  padding: 7px 20px 7px 24px;
  font-size: 12px;
  color: var(--text2);
  text-decoration: none;
  transition: all 0.12s;
  border-left: 2px solid transparent;
  font-family: var(--mono);
  letter-spacing: 0.5px;
}
.sb-link:hover {
  color: var(--amber);
  background: var(--bg3);
  border-left-color: var(--amber);
}
.sb-link.active {
  color: var(--amber);
  border-left-color: var(--amber);
  background: var(--bg3);
}
.sb-link.sub {
  padding-left: 36px;
  font-size: 11px;
  color: var(--text3);
}
.sb-link.sub:hover { color: var(--text); border-left-color: var(--border2); }

.sb-footer {
  margin-top: auto;
  padding: 14px 20px;
  border-top: 1px solid var(--border2);
  font-size: 10px;
  color: var(--text3);
  font-family: var(--mono);
}

/* ── MAIN CONTENT ── */
.main {
  flex: 1;
  min-width: 0;
  padding: 0 60px 80px;
  max-width: 900px;
}

/* ── HERO ── */
.hero {
  padding: 48px 0 40px;
  border-bottom: 1px solid var(--border2);
  margin-bottom: 48px;
}
.hero-eyebrow {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 3px;
  margin-bottom: 12px;
}
.hero-title {
  font-family: var(--display);
  font-size: 36px;
  font-weight: 900;
  color: var(--amber);
  letter-spacing: 6px;
  line-height: 1.1;
}
.hero-sub {
  font-family: var(--display);
  font-size: 13px;
  color: var(--text2);
  letter-spacing: 3px;
  margin-top: 8px;
}
.hero-desc {
  margin-top: 20px;
  color: var(--text2);
  font-size: 14px;
  max-width: 620px;
  line-height: 1.8;
}
.hero-badges {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 20px;
}
.badge {
  font-family: var(--mono);
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 2px;
  border: 1px solid;
  letter-spacing: 1px;
}
.badge-green { border-color: var(--green); color: var(--green); }
.badge-amber { border-color: var(--amber); color: var(--amber); }
.badge-blue  { border-color: var(--blue);  color: var(--blue); }
.badge-red   { border-color: var(--red);   color: var(--red); }

/* ── SECTIONS ── */
section { margin-bottom: 56px; }

.section-label {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 3px;
  margin-bottom: 6px;
}
h2 {
  font-family: var(--display);
  font-size: 18px;
  font-weight: 700;
  color: var(--amber);
  letter-spacing: 3px;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border2);
}
h3 {
  font-family: var(--mono);
  font-size: 13px;
  color: var(--text);
  letter-spacing: 1.5px;
  margin: 28px 0 10px;
}
h4 {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text2);
  letter-spacing: 1px;
  margin: 18px 0 6px;
}

p { color: var(--text2); margin-bottom: 12px; font-size: 14px; }

/* ── CODE BLOCKS ── */
pre {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-left: 3px solid var(--amber);
  border-radius: 2px;
  padding: 16px 20px;
  overflow-x: auto;
  margin: 14px 0;
  font-family: var(--mono);
  font-size: 12px;
  line-height: 1.7;
}
pre::-webkit-scrollbar { height: 4px; }
pre::-webkit-scrollbar-track { background: var(--bg2); }
pre::-webkit-scrollbar-thumb { background: var(--border2); }

code {
  font-family: var(--mono);
  font-size: 12px;
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 1px 6px;
  border-radius: 2px;
  color: var(--amber2);
}
pre code {
  background: transparent;
  border: none;
  padding: 0;
  color: var(--text);
}

.c-key   { color: var(--amber); }
.c-str   { color: var(--green); }
.c-com   { color: var(--text3); font-style: italic; }
.c-fn    { color: var(--blue); }
.c-num   { color: var(--purple); }
.c-kw    { color: var(--red); }

/* ── TABLES ── */
table {
  width: 100%;
  border-collapse: collapse;
  margin: 14px 0;
  font-size: 12px;
  font-family: var(--mono);
}
th {
  background: var(--bg3);
  border: 1px solid var(--border2);
  padding: 8px 12px;
  text-align: left;
  color: var(--amber);
  font-size: 10px;
  letter-spacing: 1.5px;
}
td {
  border: 1px solid var(--border);
  padding: 7px 12px;
  color: var(--text2);
  vertical-align: top;
}
tr:hover td { background: var(--bg3); }

/* ── CALLOUT BOXES ── */
.callout {
  border: 1px solid;
  border-radius: 2px;
  padding: 14px 18px;
  margin: 16px 0;
  font-size: 13px;
  line-height: 1.7;
}
.callout-title {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 2px;
  margin-bottom: 6px;
}
.callout-info  { border-color: var(--blue);  background: rgba(0,180,216,0.06); }
.callout-info  .callout-title { color: var(--blue); }
.callout-warn  { border-color: var(--amber); background: rgba(245,166,35,0.06); }
.callout-warn  .callout-title { color: var(--amber); }
.callout-ok    { border-color: var(--green); background: rgba(0,214,143,0.06); }
.callout-ok    .callout-title { color: var(--green); }
.callout-error { border-color: var(--red);   background: rgba(255,69,96,0.06); }
.callout-error .callout-title { color: var(--red); }
.callout p { margin: 0; color: var(--text2); }

/* ── MODULE CARDS ── */
.module-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin: 16px 0;
}
.module-card {
  background: var(--bg2);
  border: 1px solid var(--border2);
  padding: 14px 16px;
}
.module-card-id {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 2px;
  margin-bottom: 4px;
}
.module-card-name {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--amber);
  margin-bottom: 6px;
  font-weight: bold;
}
.module-card-desc {
  font-size: 12px;
  color: var(--text2);
  line-height: 1.5;
}
.module-tag {
  display: inline-block;
  font-family: var(--mono);
  font-size: 9px;
  padding: 1px 7px;
  border-radius: 2px;
  margin-top: 8px;
  border: 1px solid var(--border2);
  color: var(--text3);
}
.module-tag.lazy { border-color: var(--blue); color: var(--blue); }
.module-tag.live { border-color: var(--green); color: var(--green); }
.module-tag.new  { border-color: var(--amber); color: var(--amber); }

/* ── API CARDS ── */
.api-card {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-left: 3px solid var(--amber);
  margin: 14px 0;
  overflow: hidden;
}
.api-card-header {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--bg3);
}
.api-card-name {
  font-family: var(--display);
  font-size: 13px;
  color: var(--amber);
  letter-spacing: 2px;
  font-weight: 700;
}
.api-card-url {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text3);
}
.api-card-tier {
  margin-left: auto;
  font-family: var(--mono);
  font-size: 9px;
  padding: 2px 8px;
  border-radius: 2px;
  border: 1px solid var(--green);
  color: var(--green);
}
.api-card-body {
  padding: 14px 18px;
}
.api-card-body p { font-size: 13px; margin-bottom: 10px; }

/* ── STEP LIST ── */
.steps { counter-reset: step; list-style: none; margin: 14px 0; }
.steps li {
  counter-increment: step;
  display: flex;
  gap: 16px;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
  align-items: flex-start;
}
.steps li:last-child { border-bottom: none; }
.step-num {
  font-family: var(--display);
  font-size: 11px;
  color: var(--bg);
  background: var(--amber);
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 900;
  content: counter(step);
  margin-top: 2px;
}
.step-body { flex: 1; }
.step-title { font-family: var(--mono); font-size: 12px; color: var(--text); margin-bottom: 4px; letter-spacing: 0.5px; }
.step-desc  { font-size: 13px; color: var(--text2); }

/* ── INLINE DIVIDER ── */
.divider {
  border: none;
  border-top: 1px solid var(--border2);
  margin: 32px 0;
}

/* ── ANCHOR OFFSET ── */
[id] { scroll-margin-top: 24px; }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .sidebar { display: none; }
  .main { padding: 0 24px 60px; }
  .module-grid { grid-template-columns: 1fr; }
}
</style>
</head>
